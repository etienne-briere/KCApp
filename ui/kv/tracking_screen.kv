#:import dp kivy.metrics.dp
#:import MatplotFigure kivy_matplotlib_widget.uix.graph_widget

<TrackingScreen>: 
    
    AnchorLayout:
        anchor_x: "center"
        anchor_y: "center"

        MDBoxLayout:
            id: tracking_content
            orientation: "vertical"
            spacing: dp(20)
            padding: dp(20)
            size_hint: 1, None
            height: self.minimum_height

            # ==== Contenu de la FC brute ====
            MDBoxLayout:
                id: hr_content
                orientation: "horizontal"
                spacing: dp(10)
                size_hint: None, None
                width: self.minimum_width
                height: dp(100)
                pos_hint:{"center_x": 0.5}

                MDIcon:
                    id: heart_icon
                    icon: "heart"
                    theme_text_color: "Custom"
                    text_color: "red"
                    font_size: "40sp"
                        
                MDLabel:
                    id: heart_rate_label
                    text: root.heart_rate_label
                    font_style: "H5"
                    theme_text_color: "Primary"
                    size_hint_x: None
                    text_size: None, None
            
            # ==== Contenu du graphique de l'évolution de la FC ====
            MDBoxLayout:
                id: graph_hr_content
                orientation: "horizontal"
                spacing: dp(10)
                size_hint: 1, None
                height: dp(300)
                
                # --- Graphique ---
                MatplotFigure:
                    id: hr_graph_widget
                    size_hint: 0.9, 1

        
    








