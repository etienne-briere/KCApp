<PilotageScreen>:

    AnchorLayout:
        anchor_x: "left"
        anchor_y: "center"

        MDBoxLayout:
            orientation: "vertical"
            spacing: dp(20)
            padding: dp(20)
            size_hint: 1, None
            height: self.minimum_height

            MDBoxLayout:
                orientation: "horizontal"
                spacing: dp(12)
                size_hint_x: 1
                height: dp(48)

                MDCheckbox:
                    id: obs_checkbox
                    size_hint_x: None
                    #width: dp(48)
                    on_press: print(self)

                MDLabel:
                    text: "Obstacles"
                    font_style: "Body1"
                    halign: "left"
                    valign: "middle"
