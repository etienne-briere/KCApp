
<ScanScreen>: 

    AnchorLayout:
        anchor_x: "center"
        anchor_y: "center"

        MDBoxLayout:
            id: scan_content
            orientation: "vertical"
            spacing: dp(50)
            padding: dp(50)
            size_hint: 1, None
            height: self.minimum_height

            # ==== Card pour les données (FC + Batterie) ====
            MDCard:
                id: data_device_card
                orientation: "horizontal"
                padding: dp(20)
                spacing: dp(20)
                size_hint_y: None
                height: dp(100)
                elevation: 5
            
                # ==== Affichage FC ====
                AnchorLayout:
                    anchor_x: "center"
                    anchor_y: "center"

                    MDBoxLayout:
                        orientation: "horizontal"
                        spacing: dp(10)
                        size_hint_x: None
                        width: self.minimum_width

                        MDIcon:
                            id: heart_icon
                            icon: "heart"
                            theme_text_color: "Custom"
                            text_color: "red"
                            font_size: "40sp"
                            pos_hint:{"center_y": 0.5}
                        
                        MDLabel:
                            id: heart_rate_label
                            text: "--"
                            font_style: "H5"
                            theme_text_color: "Primary"
                            size_hint_x: None
                            text_size: None, None
                
                # ==== Séparateur ====
                Widget:
                    size_hint_x: None
                    width: dp(1)
                    canvas:
                        Color:
                            rgba: app.theme_cls.divider_color
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    
                # ===== Affichage Batterie ====
                AnchorLayout:
                    anchor_x: "center"
                    anchor_y: "center"

                    MDBoxLayout:
                        orientation: "horizontal"
                        spacing: dp(10)
                        size_hint_x: None
                        width: self.minimum_width
                        
                        MDIcon:
                            id: battery_icon
                            icon: root.battery_icon
                            theme_text_color: "Custom"
                            text_color: root.battery_color
                            font_size: "40sp"
                        
                        MDLabel:
                            id: battery_label
                            text: "-- %"
                            font_style: "H5"
                            theme_text_color: "Primary"
                            size_hint_x: None
                            text_size: None, None
            
            # ===== Zone de scan =====
            MDBoxLayout:
                id: scan_devices_content
                orientation: "vertical"
                pos_hint: {"center_x": 0.5}
                spacing: dp(15)
                size_hint: (0.9, None)
                height: self.minimum_height

                # ===== Bouton Scan =====
                MDRaisedButton:
                    text: "Scan Devices"
                    pos_hint: {"center_x": 0.5}
                    font_size: dp(20)
                    size_hint: 0.8, None
                    on_release: root.start_ble_scan()
                    height: dp(20)

                # ===== Bouton déroulant contenant la liste =====
                MDRectangleFlatIconButton:
                    id: devices_list_button
                    text:"..."
                    text_color:"white"
                    font_size: dp(20)
                    line_color:"white"
                    line_width:1
                    pos_hint:{"center_x": 0.5}
                    size_hint: 0.8, None
                    on_release: root.open_devices_menu(self)
                    height: dp(20)